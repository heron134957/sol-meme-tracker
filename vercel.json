{
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/leaderboard", "destination": "/leaderboard.html" },
    { "source": "/:path*", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/pump-alerts",
      "schedule": "0 * * * *"
    }
  ]
}
